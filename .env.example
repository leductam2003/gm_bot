# Copy to .env (gitignored) and fill in your own values.
# Everything here can also be set in the in-app Settings tab.

# Default Ethereum mainnet RPC (your provider URL).
ZYPER_ETH_RPC=

# OpenSea API key(s). Add more than one (newline or comma separated) to auto-rotate
# and dodge rate limits — if one key errors, the next is used.
OPENSEA_API_KEY=

# Etherscan V2 (multichain) API key — used for ABI fetch + tx replay.
ETHERSCAN_API_KEY=

# --- Optional / advanced ---

# Shared secret required for REMOTE API access (sent as the X-Auth-Token header).
# Leave empty for normal desktop use; remote access is refused without it.
ZYPER_AUTH_TOKEN=

# Set to 1 to run server-only (no native window) and open the dashboard in a browser.
# ZYPER_HEADLESS=1

# Bind address. Default is a random loopback port (127.0.0.1:0). Only set this for
# an intentional headless/VPS deployment.
# ZYPER_ADDR=127.0.0.1:8890
